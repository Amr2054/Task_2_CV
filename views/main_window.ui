   <string>
    /* Global Styles */
    QMainWindow { background-color: #2b2b2b; color: #f0f0f0; }
    QWidget { font-family: 'Segoe UI', Helvetica, Arial, sans-serif; font-size: 10pt; }
    QLabel { color: #f0f0f0; }

    /* Group Boxes */
    QGroupBox { font-weight: bold; border: 1px solid #555555; border-radius: 6px; margin-top: 15px; padding-top: 10px; }
    QGroupBox::title { subcontrol-origin: margin; left: 10px; padding: 0 5px; color: #4DA8DA; }

    /* Standard Buttons */
    QPushButton { background-color: #4DA8DA; color: white; border-radius: 4px; padding: 8px; font-weight: bold; }
    QPushButton:hover { background-color: #3b8bb8; }
    QPushButton:pressed { background-color: #2a6a8c; }
    QPushButton:disabled { background-color: #444444; color: #777777; }

    /* The NEW Giant Upload Button */
    #btnOpenImage {
    background-color: #2E8B57; /* SeaGreen Accent */
    border: 2px solid #3CB371;
    color: white;
    font-size: 13pt;
    font-weight: bold;
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 5px;
    }
    #btnOpenImage:hover { background-color: #3CB371; }
    #btnOpenImage:pressed { background-color: #228B22; border: 2px solid #228B22; }

    /* Tabs */
    QTabWidget::pane { border: 1px solid #555555; border-radius: 4px; top: -1px; background-color: #333333; }
    QTabBar::tab { background: #222222; color: #aaaaaa; padding: 8px 16px; border: 1px solid #555555; border-bottom: none; border-top-left-radius: 4px; border-top-right-radius: 4px; margin-right: 2px; }
    QTabBar::tab:selected { background: #333333; color: #4DA8DA; font-weight: bold; }
    QTabBar::tab:hover:!selected { background: #2a2a2a; color: #ffffff; }

    /* Inputs */
    QSpinBox, QSlider { background-color: #1e1e1e; color: white; border: 1px solid #555555; border-radius: 3px; padding: 3px; }
    QCheckBox { color: #f0f0f0; spacing: 8px; }
    QCheckBox::indicator { width: 16px; height: 16px; border-radius: 3px; border: 1px solid #555555; background: #1e1e1e; }
    QCheckBox::indicator:checked { background: #4DA8DA; }

    /* Text Outputs */
    QTextEdit { background-color: #1e1e1e; color: #4DA8DA; border: 1px solid #555555; border-radius: 4px; padding: 4px; }

    /* Scroll Area / Image Canvas */
    QScrollArea { background-color: #1e1e1e; border: 1px solid #111111; }
   </string>
